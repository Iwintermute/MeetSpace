<UserControl x:Class="MeetSpace.Client.Feature.Conference.Views.ConferencePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20" Background="#111827">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Conference"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="White"/>
            <TextBlock Text="conference feature / C++ backend contract"
                       Margin="0,6,0,0"
                       Foreground="#94A3B8"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Padding="16"
                CornerRadius="12"
                Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Server endpoint" Foreground="White" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Height="34"
                         Text="{Binding ServerEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Margin="0,12,0,0"
                           Text="Conference ID"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,12,0,0"
                         Height="34"
                         Text="{Binding ConferenceId, UpdateSourceTrigger=PropertyChanged}" />

                <WrapPanel Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Margin="0,16,0,0">
                    <Button Content="Connect" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding ConnectCommand}" />
                    <Button Content="Disconnect" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding DisconnectCommand}" />
                    <Button Content="Create" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding CreateConferenceCommand}" />
                    <Button Content="Get" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding GetConferenceCommand}" />
                    <Button Content="Join" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding JoinConferenceCommand}" />
                    <Button Content="Leave" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding LeaveConferenceCommand}" />
                    <Button Content="List Members" Width="130" Height="36" Margin="0,0,10,10" Command="{Binding ListMembersCommand}" />
                    <Button Content="Refresh" Width="110" Height="36" Margin="0,0,10,10" Command="{Binding RefreshConferenceCommand}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Padding="16" Margin="0,0,10,0" CornerRadius="12" Background="#0B1220">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Connection" Foreground="#94A3B8"/>
                    <TextBlock Grid.Column="1" Text="{Binding ConnectionState}" Foreground="White"/>

                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Trusted peer" Foreground="#94A3B8"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding TrustedPeer}" Foreground="White"/>

                    <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="Conference" Foreground="#94A3B8"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="{Binding ActiveConferenceId}" Foreground="White"/>

                    <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="Owner" Foreground="#94A3B8"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="{Binding OwnerPeerId}" Foreground="White"/>

                    <TextBlock Grid.Row="4" Margin="0,8,0,0" Text="Revision" Foreground="#94A3B8"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Text="{Binding Revision}" Foreground="White"/>

                    <TextBlock Grid.Row="5" Margin="0,8,0,0" Text="Closed" Foreground="#94A3B8"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Text="{Binding IsClosed}" Foreground="White"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="16" Margin="10,0,0,0" CornerRadius="12" Background="#0B1220">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Members"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="{Binding MemberCount, StringFormat=Count: {0}}"
                               Foreground="#94A3B8"/>

                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding MembersText}"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,20,0,0"
                Padding="16"
                CornerRadius="12"
                Background="#0B1220">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Server activity"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LastServerMessage}"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap"/>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Margin="0,12,0,0"
                           Text="{Binding LastError}"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

