<Page
    x:Class="MeetSpace.Views.Temporary.DirectCallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fa="http://schemas.fontawesome.com/icons/fonts"
    xmlns:vm="using:MeetSpace.ViewModels.Temporary"
    mc:Ignorable="d"
    Background="#05070B">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="96" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Padding="16,12"
            Background="#131C28"
            BorderBrush="#243548"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Click="BackButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FontAwesome
                            Width="14"
                            Height="14"
                            Icon="Solid_ArrowLeft" />
                        <TextBlock Text="Назад" />
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="1">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.CallTitle, Mode=OneWay}" />
                    <TextBlock
                        FontSize="12"
                        Opacity="0.74"
                        Text="{x:Bind ViewModel.CallSubtitle, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="12"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.CallStatusText, Mode=OneWay}" />
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="11"
                        Opacity="0.68"
                        Text="{x:Bind ViewModel.StatusDetailsText, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid
            Grid.Row="1"
            Padding="12"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Background="#0A1119"
                BorderBrush="#223043"
                BorderThickness="1"
                CornerRadius="10">
                <Grid x:Name="MediaHostContainer">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.72"
                        Text="Подключение медиа..." />
                </Grid>
            </Border>
            <Border
                Grid.Column="1"
                Background="#121C28"
                BorderBrush="#223043"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Участники звонка" />
                    <ListView
                        ItemsSource="{x:Bind ViewModel.Participants, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DirectCallParticipantViewItem">
                                <Grid Padding="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Opacity="0.8"
                                        Text="{x:Bind MediaSummary}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
        <Grid
            Grid.Row="2"
            Padding="0,0,0,16"
            VerticalAlignment="Bottom">
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12">
                <Button
                    IsEnabled="{x:Bind ViewModel.IsMicrophoneButtonEnabled, Mode=OneWay}"
                    Click="MicrophoneButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FontAwesome
                            Width="14"
                            Height="14"
                            Icon="Solid_Microphone" />
                        <TextBlock Text="{x:Bind ViewModel.MicrophoneButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    IsEnabled="{x:Bind ViewModel.IsCameraButtonEnabled, Mode=OneWay}"
                    Click="CameraButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FontAwesome
                            Width="14"
                            Height="14"
                            Icon="Solid_Video" />
                        <TextBlock Text="{x:Bind ViewModel.CameraButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    IsEnabled="{x:Bind ViewModel.IsScreenShareButtonEnabled, Mode=OneWay}"
                    Click="ScreenShareButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Share" />
                        <TextBlock Text="{x:Bind ViewModel.ScreenShareButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button
                    IsEnabled="{x:Bind ViewModel.IsEndCallEnabled, Mode=OneWay}"
                    Click="EndCallButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FontAwesome
                            Width="14"
                            Height="14"
                            Icon="Solid_PhoneSlash" />
                        <TextBlock Text="Завершить звонок" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
