<Page
    x:Class="MeetSpace.Views.Temporary.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:chat="using:MeetSpace.Client.Domain.Chat"
    xmlns:controls="using:MeetSpace.Views.UserControls"
    xmlns:vm="using:MeetSpace.ViewModels.Temporary"
    mc:Ignorable="d"
    Background="{ThemeResource MicaDarkerBrush}"
    BorderBrush="{ThemeResource MicaBorderBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            BorderBrush="{ThemeResource MicaBorderBrush}"
            BorderThickness="0,0,1,0"
            Background="{ThemeResource MicaDarkerBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Padding="12,12,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox
                        x:Name="DialogsSearchBox"
                        PlaceholderText="Поиск по диалогам"
                        TextChanged="DialogsSearchBox_TextChanged" />
                    <Button
                        Grid.Column="1"
                        Content="Сброс"
                        Click="ResetSearchButton_Click" />
                </Grid>

                <Border Grid.Row="1" Margin="12,0,12,8" Padding="8" Background="#101A26" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Найти пользователя по email" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="UserSearchBox"
                                PlaceholderText="email@example.com"
                                KeyUp="UserSearchBox_KeyUp" />
                            <Button
                                Grid.Column="1"
                                Content="Найти"
                                Click="SearchUsersButton_Click" />
                        </Grid>
                        <TextBlock
                            FontSize="12"
                            Opacity="0.75"
                            Text="{x:Bind ViewModel.UserSearchStatusText, Mode=OneWay}" />
                        <ListView
                            x:Name="UserSearchResultsList"
                            MaxHeight="180"
                            ItemsSource="{x:Bind ViewModel.UserSearchResults, Mode=OneWay}"
                            SelectionMode="Single"
                            IsItemClickEnabled="True"
                            ItemClick="UserSearchResultsList_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="chat:DirectUserSearchItem">
                                    <StackPanel Padding="6,4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                        <TextBlock FontSize="12" Opacity="0.75" Text="{x:Bind Email}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <ListView
                    x:Name="DialogsList"
                    Grid.Row="2"
                    ItemsSource="{x:Bind ViewModel.FilteredDialogs, Mode=OneWay}"
                    SelectionMode="Single"
                    IsItemClickEnabled="True"
                    SelectionChanged="DialogsList_SelectionChanged"
                    Background="Transparent"
                    BorderThickness="0">

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="chat:ChatDialogItem">
                            <Grid Height="72" Padding="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Width="40"
                                    Height="40"
                                    VerticalAlignment="Top"
                                    Background="#4C8DDA"
                                    CornerRadius="20">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind AvatarText}" />
                                </Grid>

                                <StackPanel Grid.Column="1" Margin="12,0,8,0" Spacing="2">
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="{x:Bind LastMessagePreview}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.55"
                                        Text="{x:Bind Subtitle}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="6">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind DisplayTime}" />

                                    <Border
                                        MinWidth="20"
                                        Height="20"
                                        Padding="6,0"
                                        HorizontalAlignment="Right"
                                        Background="#4C8DDA"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind UnreadCount}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#0E1621">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#17212B"
                BorderBrush="{ThemeResource MicaBorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Background="#4C8DDA"
                        CornerRadius="20">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.ActiveDialogAvatarText, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.ActiveDialogTitle, Mode=OneWay}" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.7"
                            Text="{x:Bind ViewModel.ActiveDialogSubtitle, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button
                            IsEnabled="{x:Bind ViewModel.IsStartAudioCallEnabled, Mode=OneWay}"
                            Click="StartAudioCallButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Phone" />
                                <TextBlock Text="Аудио" />
                            </StackPanel>
                        </Button>
                        <Button
                            IsEnabled="{x:Bind ViewModel.IsStartVideoCallEnabled, Mode=OneWay}"
                            Click="StartVideoCallButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Video" />
                                <TextBlock Text="Видео" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <controls:DirectCallIncomingOverlay
                Grid.Row="1"
                Margin="12,8,12,0"
                Visibility="{x:Bind ViewModel.IncomingCallVisibility, Mode=OneWay}"
                IncomingCallText="{x:Bind ViewModel.IncomingCallText, Mode=OneWay}"
                AcceptAudioRequested="IncomingCallOverlay_AcceptAudioRequested"
                AcceptVideoRequested="IncomingCallOverlay_AcceptVideoRequested"
                DeclineRequested="IncomingCallOverlay_DeclineRequested" />

            <Grid
                Grid.Row="2"
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="14,6"
                    Background="#1E2C3A"
                    CornerRadius="14">
                    <TextBlock Text="Выберите, кому хотели бы написать" />
                </Border>
            </Grid>

            <ListView
                x:Name="MessagesList"
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.DisplayedMessages, Mode=OneWay}"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.MessagesVisibility, Mode=OneWay}"
                Background="#0E1621"
                BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DirectChatMessageViewItem">
                        <Grid Padding="14,6">
                            <Border
                                MaxWidth="720"
                                Padding="12,8"
                                HorizontalAlignment="{x:Bind BubbleAlignment}"
                                Background="{x:Bind BubbleBackground}"
                                CornerRadius="14"
                                BorderBrush="#223446"
                                BorderThickness="1">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Opacity="0.86"
                                        Text="{x:Bind SenderTitle}" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.66"
                                        Text="{x:Bind SenderMeta}" />
                                    <TextBlock
                                        Text="{x:Bind Text}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind FooterText}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border
                Grid.Row="3"
                Padding="12"
                Background="#17212B"
                BorderBrush="{ThemeResource MicaBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{x:Bind ViewModel.ComposerVisibility, Mode=OneWay}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="MessageTextBox"
                        MinHeight="44"
                        MaxHeight="120"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        PlaceholderText="Сообщение..." />
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Click="SendButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Send" />
                            <TextBlock Text="Отправить" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
