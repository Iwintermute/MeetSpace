<Page
    x:Class="MeetSpace.Views.Temporary.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MeetSpace.Views.Temporary"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:chat="using:MeetSpace.Client.Domain.Chat"
    mc:Ignorable="d"
    Background="{ThemeResource MicaDarkerBrush}"
    BorderBrush="{ThemeResource MicaBorderBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левый список диалогов -->
        <Border
            Grid.Column="0"
            BorderBrush="{ThemeResource MicaBorderBrush}"
            BorderThickness="0,0,1,0"
            Background="{ThemeResource MicaDarkerBrush}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Padding="12,12,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox
    x:Name="DialogsSearchBox"
    PlaceholderText="Поиск"
    TextChanged="DialogsSearchBox_TextChanged"
/>

                    <Button
    x:Name="ResetSearchButton"
    Grid.Column="1"
    Content="Сброс"
    Click="ResetSearchButton_Click"
/>
                </Grid>

                <ListView
                    x:Name="DialogsList"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.FilteredDialogs, Mode=OneWay}"
                    SelectionMode="Single"
                    IsItemClickEnabled="True"
                    SelectionChanged="DialogsList_SelectionChanged"
                    Background="Transparent"
                    BorderThickness="0">

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="chat:ChatDialogItem">
                            <Grid Height="72" Padding="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Width="40"
                                    Height="40"
                                    VerticalAlignment="Top"
                                    Background="#4C8DDA"
                                    CornerRadius="20">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind AvatarText}" />
                                </Grid>

                                <StackPanel Grid.Column="1" Margin="12,0,8,0" Spacing="2">
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis" />

                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="{x:Bind LastMessagePreview}"
                                        TextTrimming="CharacterEllipsis" />

                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.55"
                                        Text="{x:Bind Subtitle}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="6">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind DisplayTime}" />

                                    <Border
                                        MinWidth="20"
                                        Height="20"
                                        Padding="6,0"
                                        HorizontalAlignment="Right"
                                        Background="#4C8DDA"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind UnreadCount}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border
                Grid.Row="0"
                Background="#17212B"
                BorderBrush="{ThemeResource MicaBorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Background="#4C8DDA"
                        CornerRadius="20">
                        <TextBlock
                            x:Name="ActiveDialogAvatarTextBlock"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.ActiveDialogAvatarText, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="ActiveDialogTitleTextBlock"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.ActiveDialogTitle, Mode=OneWay}" />
                        <TextBlock
                            x:Name="ActiveDialogSubtitleTextBlock"
                            FontSize="12"
                            Opacity="0.7"
                            Text="{x:Bind ViewModel.ActiveDialogSubtitle, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Empty state -->
            <Grid x:Name="EmptyStateGrid" Grid.Row="1" Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="14,6"
                    Background="#1E2C3A"
                    CornerRadius="14">
                    <TextBlock Text="Выберите, кому хотели бы написать" />
                </Border>
            </Grid>

            <!-- Messages -->
            <ListView
                x:Name="MessagesList"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.MessagesVisibility, Mode=OneWay}"
                Background="#0E1621"
                BorderThickness="0">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="chat:ChatMessageItem">
                        <Grid Padding="16,4">
                            <Border
                                MaxWidth="640"
                                Padding="12,8"
                                Background="#2B5278"
                                CornerRadius="14"
                                HorizontalAlignment="Left">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="{x:Bind Text}"
                                        TextWrapping="WrapWholeWords" />

                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind DisplayTime}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Composer -->
            <Border
                x:Name="ComposerBorder"
                Grid.Row="2"
                Padding="12"
                Background="#17212B"
                BorderBrush="{ThemeResource MicaBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{x:Bind ViewModel.ComposerVisibility, Mode=OneWay}">

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="MessageTextBox"
                        MinHeight="44"
                        MaxHeight="120"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        PlaceholderText="Сообщение..." />

                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Content="Send"
                        Click="SendButton_Click" />
                </Grid>
            </Border>

            <!-- Технический блок не удаляем, просто прячем -->
            <StackPanel
                x:Name="DebugConnectionPanel"
                Grid.Row="2"
                Visibility="Collapsed"
                Orientation="Horizontal"
                Spacing="8">
                <TextBox
                    x:Name="EndpointTextBox"
                    Width="260"
                    Header="WebSocket endpoint"
                    Text="ws://127.0.0.1:9002" />
                <TextBox
                    x:Name="ConferenceIdTextBox"
                    Width="220"
                    Header="Conversation ID"
                    PlaceholderText="dm-peer-id" />
                <Button Content="Connect" Click="ConnectButton_Click" />
                <Button Content="Disconnect" Click="DisconnectButton_Click" />
                <Button Content="Create" Click="CreateConferenceButton_Click" />
                <Button Content="Join" Click="JoinConferenceButton_Click" />
                <TextBlock x:Name="ConnectionTextBlock" Text="{x:Bind ViewModel.ConnectionText, Mode=OneWay}" />
                <TextBlock x:Name="PeerTextBlock" Text="{x:Bind ViewModel.PeerText, Mode=OneWay}" />
                <TextBlock x:Name="ErrorTextBlock" Foreground="IndianRed" Text="{x:Bind ViewModel.ErrorText, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>