<Page
    x:Class="MeetSpace.Views.Temporary.ConferenceRoomPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MeetSpace.Views.Temporary"
    xmlns:vm="using:MeetSpace.ViewModels.Temporary"
    mc:Ignorable="d"
    Background="#05070B">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="96" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="{x:Bind ViewModel.ChatPanelWidth, Mode=OneWay}" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Padding="12" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="10,8"
                    Background="#131C28"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            x:Name="AuthorizedUserTextBlock"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.AuthorizedUserText, Mode=OneWay}" />
                        <TextBlock
                            x:Name="AuthorizedUserMetaTextBlock"
                            Opacity="0.8"
                            Text="{x:Bind ViewModel.AuthorizedUserMetaText, Mode=OneWay}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Opacity="0.8"
                            Text="{x:Bind ViewModel.CallStatusText, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="#0A1119"
                    BorderBrush="#223043"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid x:Name="MediaHostContainer" />
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="8"
                    Background="#121C28"
                    CornerRadius="8">
                    <ListView
                        x:Name="ParticipantsList"
                        ItemsSource="{x:Bind ViewModel.Participants, Mode=OneWay}"
                        SelectionMode="None"
                        MaxHeight="130">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConferenceParticipantTileViewItem">
                                <Grid Padding="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Opacity="0.75"
                                        Text="{x:Bind MediaSummary}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <Border
                x:Name="ChatPanel"
                Grid.Column="1"
                Background="#171A1F"
                BorderBrush="#22000000"
                BorderThickness="1"
                Visibility="{x:Bind ViewModel.ChatPanelVisibility, Mode=OneWay}">

                <Grid Padding="16" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Чат встречи"
                            FontSize="20"
                            FontWeight="SemiBold" />

                        <Button
                            Grid.Column="1"
                            Content="✕"
                            Click="CloseChatButton_Click" />
                    </Grid>

                    <ListView
                        x:Name="MessagesList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                        SelectionMode="None">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ConferenceChatMessageViewItem">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock
                                        Text="{x:Bind SenderDisplayName}"
                                        FontWeight="SemiBold" />

                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="12"
                                        Background="#222831"
                                        CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock
                                                Text="{x:Bind Text}"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Opacity="0.7"
                                                Text="{x:Bind DisplayTime}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="MessageTextBox"
                            PlaceholderText="Отправьте сообщение"
                            AcceptsReturn="True"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Content="➤"
                            Click="SendMessageButton_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="0,0,0,16"
            VerticalAlignment="Bottom">
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12">
                <Button
                    x:Name="MicrophoneButton"
                    IsEnabled="{x:Bind ViewModel.IsMicrophoneButtonEnabled, Mode=OneWay}"
                    Click="MicrophoneButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Microphone" />
                        <TextBlock Text="{x:Bind ViewModel.MicrophoneButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="CameraButton"
                    IsEnabled="{x:Bind ViewModel.IsCameraButtonEnabled, Mode=OneWay}"
                    Click="CameraButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Video" />
                        <TextBlock Text="{x:Bind ViewModel.CameraButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="ScreenShareButton"
                    IsEnabled="{x:Bind ViewModel.IsScreenShareButtonEnabled, Mode=OneWay}"
                    Click="ScreenShareButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Share" />
                        <TextBlock Text="{x:Bind ViewModel.ScreenShareButtonContent, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <Button Click="OpenChatButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Message" />
                        <TextBlock Text="Чат" />
                    </StackPanel>
                </Button>
                <Button Click="LeaveConferenceButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Cancel" />
                        <TextBlock Text="Завершить" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
