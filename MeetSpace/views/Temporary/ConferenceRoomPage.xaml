<Page
    x:Class="MeetSpace.Views.Temporary.ConferenceRoomPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MeetSpace.Views.Temporary"
    mc:Ignorable="d"
    Background="#05070B">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="88" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Padding="12">
                <!-- ВАЖНО:
                     WebView2 больше не создаём прямо в XAML.
                     Держим только контейнер, а сам control создаём в code-behind внутри try/catch. -->
                <Grid
                    x:Name="MediaHostContainer"
                    Width="1"
                    Height="1"
                    Opacity="0.01"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top" />

                <Grid>
                    <Ellipse
                        Width="84"
                        Height="84"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Fill="#33222222" />

                    <StackPanel
                        Margin="20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Spacing="4">
                        <TextBlock
                            x:Name="AuthorizedUserTextBlock"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="Авторизованный пользователь" />

                        <TextBlock
                            x:Name="AuthorizedUserMetaTextBlock"
                            Opacity="0.8"
                            Text="peer / conference" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Border
                x:Name="ChatPanel"
                Grid.Column="1"
                Background="#171A1F"
                BorderBrush="#22000000"
                BorderThickness="1"
                Visibility="Collapsed">

                <Grid Padding="16" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Чат встречи"
                            FontSize="20"
                            FontWeight="SemiBold" />

                        <Button
                            Grid.Column="1"
                            Content="✕"
                            Click="CloseChatButton_Click" />
                    </Grid>

                    <ListView
                        x:Name="MessagesList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind Messages, Mode=OneWay}"
                        SelectionMode="None">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ConferenceChatMessageViewItem">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock
                                        Text="{x:Bind SenderDisplayName}"
                                        FontWeight="SemiBold" />

                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="12"
                                        Background="#222831"
                                        CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock
                                                Text="{x:Bind Text}"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Opacity="0.7"
                                                Text="{x:Bind DisplayTime}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="MessageTextBox"
                            PlaceholderText="Отправьте сообщение"
                            AcceptsReturn="True"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Content="➤"
                            Click="SendMessageButton_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="0,0,0,16"
            VerticalAlignment="Bottom">

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12">

                <Button
                    x:Name="MicrophoneButton"
                    Content="Микрофон"
                    Click="MicrophoneButton_Click" />

                <Button Content="Камера" />
                <Button Content="Экран" />
                <Button Content="Эмодзи" />
                <Button Content="Субтитры" />
                <Button Content="Поднять руку" />
                <Button Content="Ещё" />
                <Button Content="Завершить" Click="LeaveConferenceButton_Click" />
                <Button Content="Чат" Click="OpenChatButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>