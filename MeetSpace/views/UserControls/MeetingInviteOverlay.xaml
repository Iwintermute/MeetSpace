<UserControl
    x:Class="MeetSpace.Views.UserControls.MeetingInviteOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#66000000">
        <Border
    Width="420"
    Padding="24"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    Background="{ThemeResource MicaDarkerBrush}"
    BorderBrush="{ThemeResource MicaBorderBrush}"
    BorderThickness="1"
    CornerRadius="16">

            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="Данные для подключения к встрече"
                        FontSize="32"
                        FontWeight="SemiBold"
                        TextWrapping="WrapWholeWords" />

                    <Button
                        Grid.Column="1"
                        Content="✕"
                        Click="CloseButton_Click" />
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Text="Отправьте эту информацию тем, кого хотите пригласить. Сохраните ее, если планируете встречу позже."
                    Opacity="0.85"
                    TextWrapping="WrapWholeWords" />

                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="12"
                        Background="#22000000"
                        CornerRadius="8">
                        <TextBlock
                            x:Name="LinkTextBlock"
                            TextWrapping="WrapWholeWords" />
                    </Border>

                    <Button
                        Grid.Column="1"
                        Content="Копировать"
                        Click="CopyButton_Click" />
                </Grid>

                <StackPanel
                    Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12">

                    <Button
                        Content="Закрыть"
                        Click="CloseButton_Click" />

                    <Button
                        Content="Открыть встречу"
                        Click="OpenMeetingButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>