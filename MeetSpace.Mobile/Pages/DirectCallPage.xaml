<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeetSpace.Mobile.Pages.DirectCallPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Звонок"
    BackgroundColor="{DynamicResource MicaDarkerBrush}">
    <Grid
        Padding="12"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="10">
        <Border
            Grid.Row="0"
            Style="{StaticResource CardBorderStyle}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Button
                    Style="{StaticResource ToolbarButton}"
                    Text="←"
                    Clicked="BackButton_Clicked" />
                <VerticalStackLayout Grid.Column="1">
                    <Label
                        Style="{StaticResource PageTitleLabelStyle}"
                        Text="{Binding CallTitle}" />
                    <Label
                        Style="{StaticResource CaptionLabelStyle}"
                        Text="{Binding CallSubtitle}" />
                </VerticalStackLayout>
                <VerticalStackLayout
                    Grid.Column="2"
                    HorizontalOptions="End">
                    <Label
                        HorizontalTextAlignment="End"
                        Style="{StaticResource CaptionLabelStyle}"
                        Text="{Binding CallStatusText}" />
                    <Label
                        HorizontalTextAlignment="End"
                        Style="{StaticResource CaptionLabelStyle}"
                        Text="{Binding StatusDetailsText}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,280"
            ColumnSpacing="10">
            <Border
                Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
                <Grid>
                    <WebView x:Name="MediaHostView" />
                    <Label
                        HorizontalOptions="Center"
                        Opacity="0.7"
                        Text="Подключение медиа..."
                        VerticalOptions="Center" />
                </Grid>
            </Border>
            <Border
                Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Style="{StaticResource SectionTitleLabelStyle}"
                        Text="Участники звонка" />
                    <CollectionView
                        ItemsSource="{Binding Participants}"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Padding="4,4"
                                    ColumnDefinitions="*,Auto">
                                    <Label
                                        Style="{StaticResource SectionTitleLabelStyle}"
                                        Text="{Binding Title}" />
                                    <Label
                                        Grid.Column="1"
                                        Style="{StaticResource CaptionLabelStyle}"
                                        Text="{Binding MediaSummary}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ScrollView
            Grid.Row="2"
            HorizontalScrollBarVisibility="Never"
            Orientation="Horizontal">
            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="8">
                <Button
                    IsEnabled="{Binding IsMicrophoneButtonEnabled}"
                    Style="{StaticResource ToolbarButton}"
                    Text="{Binding MicrophoneButtonContent}"
                    Clicked="MicrophoneButton_Clicked" />
                <Button
                    IsEnabled="{Binding IsCameraButtonEnabled}"
                    Style="{StaticResource ToolbarButton}"
                    Text="{Binding CameraButtonContent}"
                    Clicked="CameraButton_Clicked" />
                <Button
                    IsEnabled="{Binding IsScreenShareButtonEnabled}"
                    Style="{StaticResource ToolbarButton}"
                    Text="{Binding ScreenShareButtonContent}"
                    Clicked="ScreenShareButton_Clicked" />
                <Button
                    IsEnabled="{Binding IsEndCallEnabled}"
                    Style="{StaticResource DangerButtonStyle}"
                    Text="Завершить"
                    Clicked="EndCallButton_Clicked" />
            </HorizontalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
