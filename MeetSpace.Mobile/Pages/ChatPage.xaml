<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeetSpace.Mobile.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MeetSpace.Mobile.Controls"
    Title="Чаты"
    BackgroundColor="{DynamicResource MicaDarkerBrush}">
    <Grid ColumnDefinitions="320,*" ColumnSpacing="0">
        <Border
            Grid.Column="0"
            Style="{StaticResource PaneBorderStyle}">
            <Grid
                BackgroundColor="{DynamicResource MicaDarkerBrush}"
                RowDefinitions="Auto,Auto,*"
                RowSpacing="0">
                <Border
                    Padding="12,10"
                    StrokeShape="RoundRectangle 0"
                    StrokeThickness="0">
                    <Label
                        Style="{StaticResource PageTitleLabelStyle}"
                        Text="Диалоги" />
                </Border>

                <Border
                    Grid.Row="1"
                    Margin="12,0,12,8"
                    Style="{StaticResource SurfaceAltBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Style="{StaticResource SectionTitleLabelStyle}"
                            Text="Найти пользователя по email" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Border Style="{StaticResource SurfaceAltBorderStyle}">
                                <Entry
                                    x:Name="UserSearchEntry"
                                    Placeholder="email@example.com"
                                    Completed="UserSearchEntry_Completed" />
                            </Border>
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource ToolbarButton}"
                                Text="Найти"
                                Clicked="SearchUsersButton_Clicked" />
                        </Grid>
                        <Label
                            Style="{StaticResource CaptionLabelStyle}"
                            Text="{Binding UserSearchStatusText}" />
                        <CollectionView
                            x:Name="UserSearchResultsCollection"
                            HeightRequest="180"
                            ItemsSource="{Binding UserSearchResults}"
                            SelectionMode="Single"
                            SelectionChanged="UserSearchResultsCollection_SelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,6"
                                        Style="{StaticResource SurfaceAltBorderStyle}">
                                        <VerticalStackLayout Padding="8,6" Spacing="2">
                                            <Label
                                                Style="{StaticResource SectionTitleLabelStyle}"
                                                Text="{Binding Title}" />
                                            <Label
                                                Style="{StaticResource CaptionLabelStyle}"
                                                Text="{Binding Email}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <CollectionView
                    x:Name="DialogsCollection"
                    Grid.Row="2"
                    ItemsSource="{Binding FilteredDialogs}"
                    SelectionMode="Single"
                    SelectionChanged="DialogsCollection_SelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6">
                                <Grid
                                    HeightRequest="72"
                                    ColumnDefinitions="44,*,Auto"
                                    ColumnSpacing="10">
                                    <Border
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        VerticalOptions="Start"
                                        Style="{StaticResource AvatarBorderStyle}">
                                        <Label
                                            FontAttributes="Bold"
                                            HorizontalOptions="Center"
                                            Text="{Binding AvatarText}"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Margin="2,0,0,0"
                                        Spacing="1">
                                        <Label
                                            Style="{StaticResource SectionTitleLabelStyle}"
                                            Text="{Binding Title}"
                                            LineBreakMode="TailTruncation" />
                                        <Label
                                            Style="{StaticResource CaptionLabelStyle}"
                                            Text="{Binding LastMessagePreview}"
                                            LineBreakMode="TailTruncation" />
                                        <Label
                                            Style="{StaticResource CaptionLabelStyle}"
                                            Text="{Binding Subtitle}"
                                            LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Column="2"
                                        HorizontalOptions="End"
                                        Spacing="6">
                                        <Label
                                            HorizontalTextAlignment="End"
                                            Style="{StaticResource CaptionLabelStyle}"
                                            Text="{Binding DisplayTime}" />
                                        <Border
                                            MinimumWidthRequest="20"
                                            HeightRequest="20"
                                            Padding="6,0"
                                            HorizontalOptions="End"
                                            BackgroundColor="{DynamicResource ResponsiveAccentBrush3}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="11"
                                                HorizontalTextAlignment="Center"
                                                TextColor="{DynamicResource SortHvidBrush}"
                                                Text="{Binding UnreadCount}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Grid
            Grid.Column="1"
            BackgroundColor="{DynamicResource MicaDarkerBrush}"
            RowDefinitions="72,Auto,*,Auto"
            RowSpacing="0">
            <Border
                Grid.Row="0"
                Padding="16,10"
                StrokeShape="RoundRectangle 0"
                StrokeThickness="0">
                <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"
                        Style="{StaticResource AvatarBorderStyle}">
                        <Label
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            Text="{Binding ActiveDialogAvatarText}"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Spacing="1">
                        <Label
                            Style="{StaticResource SectionTitleLabelStyle}"
                            FontSize="17"
                            Text="{Binding ActiveDialogTitle}" />
                        <Label
                            Style="{StaticResource CaptionLabelStyle}"
                            Text="{Binding ActiveDialogSubtitle}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout
                        Grid.Column="2"
                        HorizontalOptions="End"
                        Spacing="8">
                        <Button
                            IsEnabled="{Binding IsStartAudioCallEnabled}"
                            Style="{StaticResource ToolbarButton}"
                            Text="Аудио"
                            Clicked="StartAudioCallButton_Clicked" />
                        <Button
                            IsEnabled="{Binding IsStartVideoCallEnabled}"
                            Style="{StaticResource ToolbarButton}"
                            Text="Видео"
                            Clicked="StartVideoCallButton_Clicked" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <controls:DirectCallIncomingOverlay
                Grid.Row="1"
                Margin="12,8,12,0"
                IncomingCallText="{Binding IncomingCallText}"
                IsVisible="{Binding IsIncomingCallVisible}"
                AcceptAudioRequested="IncomingCallOverlay_AcceptAudioRequested"
                AcceptVideoRequested="IncomingCallOverlay_AcceptVideoRequested"
                DeclineRequested="IncomingCallOverlay_DeclineRequested" />

            <Grid Grid.Row="2">
                <Label
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsEmptyStateVisible}"
                    Opacity="0.7"
                    Text="Выберите, кому хотели бы написать"
                    VerticalOptions="Center" />

                <CollectionView
                    x:Name="MessagesCollection"
                    BackgroundColor="{DynamicResource MicaDarkerBrush}"
                    IsVisible="{Binding IsMessagesVisible}"
                    ItemsSource="{Binding DisplayedMessages}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="14,6">
                                <Border
                                    BackgroundColor="{Binding BubbleBackgroundColor}"
                                    HorizontalOptions="{Binding BubbleAlignment}"
                                    MaximumWidthRequest="720"
                                    Padding="12,8"
                                    Stroke="{StaticResource MicaBorderStrokeBrush}"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="1">
                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Opacity="0.86"
                                            Text="{Binding SenderTitle}" />
                                        <Label
                                            FontSize="11"
                                            Opacity="0.66"
                                            Text="{Binding SenderMeta}" />
                                        <Label
                                            Text="{Binding Text}"
                                            LineBreakMode="WordWrap" />
                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="End"
                                            Opacity="0.7"
                                            Text="{Binding FooterText}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Border
                Grid.Row="3"
                Padding="12"
                StrokeShape="RoundRectangle 0"
                StrokeThickness="0">
                <Grid
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8"
                    IsVisible="{Binding IsComposerVisible}">
                    <Button
                        Style="{StaticResource IconButtonStyle}"
                        Text="📎"
                        Clicked="AttachFileButton_Clicked" />
                    <Border
                        Grid.Column="1"
                        Style="{StaticResource SurfaceAltBorderStyle}">
                        <Editor
                            x:Name="MessageEditor"
                            Style="{StaticResource GlowEditorTextBox}"
                            AutoSize="TextChanges"
                            BackgroundColor="Transparent"
                            MaxLength="1500"
                            Placeholder="Сообщение..." />
                    </Border>
                    <Button
                        Grid.Column="2"
                        Style="{StaticResource ToolbarButton}"
                        Text="Отправить"
                        VerticalOptions="End"
                        Clicked="SendMessageButton_Clicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
