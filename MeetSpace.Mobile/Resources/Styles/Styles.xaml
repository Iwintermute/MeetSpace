<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{DynamicResource MicaDarkerBrush}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{DynamicResource MicaBrush}" />
        <Setter Property="BarTextColor" Value="{DynamicResource HvidSortBrush}" />
        <Setter Property="SelectedTabColor" Value="{DynamicResource ResponsiveAccentBrush3}" />
        <Setter Property="UnselectedTabColor" Value="{DynamicResource SecondaryTextColor}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{DynamicResource MicaBrush}" />
        <Setter Property="BarTextColor" Value="{DynamicResource HvidSortBrush}" />
    </Style>

    <Style x:Key="BaseLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource HvidSortBrush}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}" />

    <Style x:Key="AppTitleLabelStyle" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="PageTitleLabelStyle" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="SectionTitleLabelStyle" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="BodyMutedLabelStyle" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="TextColor" Value="{DynamicResource SecondaryTextColor}" />
    </Style>

    <Style x:Key="CaptionLabelStyle" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource SecondaryTextColor}" />
    </Style>

    <Style x:Key="Headline" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="TextColor" Value="{DynamicResource HvidSortBrush}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="SubHeadline" TargetType="Label" BasedOn="{StaticResource BaseLabelStyle}">
        <Setter Property="TextColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource MicaDarkerBrush}" />
        <Setter Property="Stroke" Value="{StaticResource MicaBorderStrokeBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource MicaDarkerBrush}" />
        <Setter Property="Stroke" Value="{StaticResource MicaBorderStrokeBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="PaneBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="StrokeShape" Value="RoundRectangle 0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="SurfaceAltBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource FABrush}" />
    </Style>

    <Style x:Key="AvatarBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource ResponsiveAccentBrush3}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
    </Style>

    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinimumHeightRequest" Value="40" />
        <Setter Property="MinimumWidthRequest" Value="40" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource HvidSortBrush}" />
    </Style>

    <Style x:Key="CardButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="BackgroundColor" Value="{DynamicResource 12Brush}" />
        <Setter Property="BorderColor" Value="{DynamicResource MicaBorderBrush}" />
    </Style>

    <Style x:Key="ToolbarToggleButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="BackgroundColor" Value="{DynamicResource 24Brush}" />
        <Setter Property="BorderColor" Value="{DynamicResource MicaBorderBrush}" />
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button" BasedOn="{StaticResource CardButton}" />
    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryButtonBackgroundColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryButtonTextColor}" />
        <Setter Property="BorderColor" Value="{DynamicResource PrimaryButtonBackgroundColor}" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource DangerButtonBackgroundColor}" />
        <Setter Property="TextColor" Value="{DynamicResource DangerButtonTextColor}" />
        <Setter Property="BorderColor" Value="{DynamicResource DangerButtonBackgroundColor}" />
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="WidthRequest" Value="44" />
    </Style>

    <Style x:Key="GlowTextBox" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{DynamicResource SortHvidBrush}" />
        <Setter Property="TextColor" Value="{DynamicResource HvidSortBrush}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="42" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="Entry" BasedOn="{StaticResource GlowTextBox}" />

    <Style x:Key="GlowEditorTextBox" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{DynamicResource SortHvidBrush}" />
        <Setter Property="TextColor" Value="{DynamicResource HvidSortBrush}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="AutoSize" Value="TextChanges" />
    </Style>

    <Style TargetType="Editor" BasedOn="{StaticResource GlowEditorTextBox}" />

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource ResponsiveAccentBrush3}" />
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{DynamicResource MicaBorderBrush}" />
        <Setter Property="HeightRequest" Value="1" />
    </Style>
</ResourceDictionary>
