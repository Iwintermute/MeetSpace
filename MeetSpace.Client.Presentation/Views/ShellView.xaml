<UserControl x:Class="MeetSpace.Client.Presentation.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#111827">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A">
            <StackPanel Margin="16">
                <TextBlock Text="MeetSpace"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <Button Content="Conference"
                        Height="40"
                        Margin="0,0,0,10"
                        Command="{Binding OpenConferenceCommand}" />

                <Button Content="Calls"
                        Height="40"
                        Margin="0,0,0,10"
                        Command="{Binding OpenCallsCommand}" />

                <Button Content="Chat"
                        Height="40"
                        Margin="0,0,0,10"
                        Command="{Binding OpenChatCommand}" />

                <Button Content="Presence"
                        Height="40"
                        Margin="0,0,0,10"
                        Command="{Binding OpenPresenceCommand}" />

                <Button Content="Settings"
                        Height="40"
                        Command="{Binding OpenSettingsCommand}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#111827">
            <ContentControl Content="{Binding CurrentContent}" />
        </Border>
    </Grid>
</UserControl>